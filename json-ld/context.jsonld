          "@id": "schema:dateModified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Environment": {
      "@id": "bc:Environment",
      "@context": {
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "friendlyName": {
          "@id": "schema:alternateName",
