{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Journal",
  "title": "Journal",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "example": "abc123"
    },
    "code": {
      "type": "string",
      "maxLength": 10,
      "example": "example_value"
    },
    "displayName": {
      "type": "string",
      "maxLength": 100,
      "example": "example_value"
    },
    "templateDisplayName": {
      "type": "string",
      "maxLength": 100,
      "example": "example_value"
    },
    "lastModifiedDateTime": {
      "type": "string",
      "format": "date-time",
      "readOnly": true,
      "example": "2026-01-15T10:30:00Z"
    },
    "balancingAccountId": {
      "type": "string",
      "format": "uuid",
      "example": "500123"
    },
    "balancingAccountNumber": {
      "type": "string",
      "maxLength": 20,
      "example": "example_value"
    }
  }
}