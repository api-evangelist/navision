{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/UserUpdate",
  "title": "UserUpdate",
  "type": "object",
  "properties": {
    "state": {
      "type": "string",
      "enum": [
        "Enabled",
        "Disabled"
      ],
      "example": "Enabled"
    },
    "expiryDate": {
      "type": "string",
      "format": "date-time",
      "example": "2026-01-15T10:30:00Z"
    }
  }
}