{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SupportSettings",
  "title": "SupportSettings",
  "type": "object",
  "properties": {
    "appId": {
      "type": "string",
      "format": "uuid",
      "example": "500123"
    },
    "supportUrl": {
      "type": "string",
      "format": "uri",
      "example": "https://www.example.com"
    },
    "supportEmail": {
      "type": "string",
      "format": "email",
      "example": "user@example.com"
    },
    "supportPhone": {
      "type": "string",
      "example": "example_value"
    }
  }
}