{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AppInstallRequest",
  "title": "AppInstallRequest",
  "type": "object",
  "properties": {
    "targetVersion": {
      "type": "string",
      "description": "Version to install",
      "example": "example_value"
    },
    "allowPreviewVersion": {
      "type": "boolean",
      "description": "Whether to allow preview versions",
      "example": true
    },
    "acceptIsvEula": {
      "type": "boolean",
      "description": "Whether the ISV EULA is accepted",
      "example": true
    },
    "allowDependencyUpdate": {
      "type": "boolean",
      "description": "Whether to also update dependent apps",
      "example": true
    }
  }
}