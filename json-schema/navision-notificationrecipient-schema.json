{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/NotificationRecipient",
  "title": "NotificationRecipient",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "example": "abc123"
    },
    "name": {
      "type": "string",
      "example": "Example Title"
    },
    "email": {
      "type": "string",
      "format": "email",
      "example": "user@example.com"
    }
  }
}